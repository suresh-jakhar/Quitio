# ===== ML Service Environment Configuration =====
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ===== Server Configuration =====
PORT=8000
ENV=development

# ===== Database Configuration =====
# Format: postgresql://username:password@host:port/database
# Use Neon (or another managed PostgreSQL) with SSL:
DATABASE_URL=postgresql://username:password@your-neon-host/neondb?sslmode=require&channel_binding=require

# ===== Backend API Configuration =====
# URL where the main backend is running (for callbacks, etc.)
BACKEND_URL=http://localhost:5000

# ===== Model Configuration =====
# Embedding model (from sentence-transformers)
MODEL_NAME=all-MiniLM-L6-v2

# Device: cpu or cuda (for GPU acceleration)
MODEL_DEVICE=cpu

# ===== API Configuration =====
# Request timeout in seconds
API_TIMEOUT=30

# Maximum batch size for processing
MAX_BATCH_SIZE=32

# ===== Optional: Logging Configuration =====
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# ===== Optional: Cache Configuration =====
# REDIS_URL=redis://localhost:6379

# ===== Optional: Rate Limiting =====
# RATE_LIMIT_PER_MINUTE=100

# ===== Optional: Monitoring =====
# SENTRY_DSN=https://key@sentry.io/project
